name: "zerorisc:dv:tl_agent_ral_pyuvm_sim:0.1"
description: "tl_agent_ral Python/pyUVM Verilator sim target"

filesets:
  files_dv:
    files:
      - ../tl_agent/rtl/tl_agent_smoke.sv: { file_type: systemVerilogSource }

targets:
  sim:
    default_tool: verilator
    filesets:
      - files_dv
    toplevel: tl_agent_smoke
