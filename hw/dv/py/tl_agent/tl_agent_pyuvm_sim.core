name: "lowrisc:dv:tl_agent_pyuvm_sim:0.1"
description: "tl_agent Python/pyUVM Verilator sim target"

filesets:
  files_dv:
    files:
      - rtl/tl_agent_smoke.sv: { file_type: systemVerilogSource }

targets:
  sim:
    default_tool: verilator
    filesets:
      - files_dv
    toplevel: tl_agent_smoke
